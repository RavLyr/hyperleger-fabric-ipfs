// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Diploma {
  id String @id @default(cuid())

  certificateId   String?   @unique
  certificateType String    @default("DIPLOMA")
  title           String?
  studentIdHash   String?
  documentHash    String?
  issuedAt        DateTime?

  studentName    String
  nim            String
  diplomaNumber  String @unique
  studyProgram   String
  graduationYear Int

  uploadedFileName     String?
  uploadedFileMimeType String?
  uploadedFileSize     Int?
  fileUrl              String?
  fileHash             String?
  ipfsCid              String?
  blockchainTxHash     String?

  status DiplomaStatus @default(VALID)

  issuerId String?
  issuer   Issuer? @relation(fields: [issuerId], references: [issuerId], onDelete: SetNull)

  revocation Revocation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([issuerId])
}

model Revocation {
  id        String  @id @default(cuid())
  diplomaId String  @unique
  diploma   Diploma @relation(fields: [diplomaId], references: [id], onDelete: Cascade)

  certificateId String
  revokedBy     String?
  reason        String?
  reasonHash    String
  revokedAt     DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([certificateId])
}

model Issuer {
  id               String       @id @default(cuid())
  issuerId         String       @unique
  organizationName String
  departmentName   String
  mspId            String
  status           IssuerStatus @default(ACTIVE)
  registeredAt     DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users    User[]
  diplomas Diploma[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ISSUER_ADMIN)

  issuerDbId String?
  issuer     Issuer? @relation(fields: [issuerDbId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DiplomaStatus {
  VALID
  INVALID
  REVOKED
}

enum IssuerStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum UserRole {
  ADMIN
  ISSUER_ADMIN
}
