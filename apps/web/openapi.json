    "/api/fabric/health": {
      "$ref": "#/paths/~1fabric~1health"
    },
    "/api/fabric/invoke": {
      "$ref": "#/paths/~1fabric~1invoke"
    },
    "/fabric/health": {
      "get": {
        "summary": "Status Koneksi Fabric Gateway",
        "description": "Memeriksa status dan kesehatan koneksi backend ke node peer Hyperledger Fabric.",
        "responses": {
          "200": {
            "description": "Connection status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": [
                            "connected",
                            "degraded"
                          ],
                          "example": "connected"
                        },
                        "itemCount": {
                          "type": "integer",
                          "nullable": true,
                          "example": null
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fabric/invoke": {
      "post": {
        "summary": "Invoke Generic Chaincode",
        "description": "Endpoint utilitas debug untuk mengirim transaksi general/custom ke chaincode.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "functionName": {
                    "type": "string",
                    "description": "Nama fungsi smart contract",
                    "example": "SmartContract:GetAllCertificates"
                  },
                  "args": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": []
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "evaluate",
                      "submit"
                    ],
                    "example": "submit"
                  }
                },
                "required": [
                  "functionName"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invocation response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "mode": {
                          "type": "string",
                          "enum": [
                            "evaluate",
                            "submit"
                          ],
                          "example": "submit"
                        },
                        "result": {
                          "nullable": true,
                          "example": []
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
