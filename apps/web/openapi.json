{
  "openapi": "3.0.3",
  "info": {
    "title": "IPFS Hyperledger Fabric Verification Backend API",
    "description": "API dokumentasi untuk sistem verifikasi ijazah terdesentralisasi menggunakan Hyperledger Fabric (blockchain) dan IPFS (decentralized storage) dengan database lokal PostgreSQL.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login Issuer Admin",
        "description": "Endpoint untuk otentikasi issuer (admin) dan mendapatkan JWT Token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "identifier": {
                    "type": "string",
                    "description": "Username, Email, atau Issuer ID",
                    "example": "admin"
                  },
                  "password": {
                    "type": "string",
                    "example": "admin123"
                  }
                },
                "required": [
                  "identifier",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login berhasil, mengembalikan token.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string",
                          "example": "eyJhbG..."
                        },
                        "issuer": {
                          "type": "object",
                          "properties": {
                            "issuerId": {
                              "type": "string"
                            },
                            "organizationName": {
                              "type": "string"
                            },
                            "departmentName": {
                              "type": "string"
                            },
                            "mspId": {
                              "type": "string"
                            },
                            "username": {
                              "type": "string"
                            },
                            "email": {
                              "type": "string"
                            },
                            "isActive": {
                              "type": "boolean"
                            },
                            "status": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Registrasi Issuer Admin Baru",
        "description": "Mendaftarkan akun issuer admin baru beserta kredensial login (hanya di database, belum didaftarkan ke blockchain ledger).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "issuerId": {
                    "type": "string",
                    "example": "NEW_ISSUER"
                  },
                  "organizationName": {
                    "type": "string",
                    "example": "New University"
                  },
                  "departmentName": {
                    "type": "string",
                    "example": "Academic Office"
                  },
                  "mspId": {
                    "type": "string",
                    "example": "Org1MSP"
                  },
                  "username": {
                    "type": "string",
                    "example": "newadmin"
                  },
                  "email": {
                    "type": "string",
                    "example": "admin@new.ac.id"
                  },
                  "password": {
                    "type": "string",
                    "example": "securepass"
                  }
                },
                "required": [
                  "issuerId",
                  "organizationName",
                  "departmentName",
                  "mspId",
                  "username",
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registrasi berhasil.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Issuer registered successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Memeriksa status hidup server backend Express.",
        "responses": {
          "200": {
            "description": "Server is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Server is running"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/ledger/init": {
      "post": {
        "summary": "Inisialisasi Ledger",
        "description": "Mempersiapkan state awal ledger blockchain dan mendaftarkan DEMO_ISSUER bawaan.",
        "responses": {
          "200": {
            "description": "Ledger initialized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Ledger initialized successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/issuers": {
      "post": {
        "summary": "Pendaftaran Issuer (Penerbit)",
        "description": "Mendaftarkan institusi penerbit ijazah baru ke dalam blockchain ledger.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterIssuerRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Issuer registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "string",
                      "example": ""
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/issuers/{issuerId}": {
      "get": {
        "summary": "Detail Issuer",
        "description": "Mendapatkan data institusi issuer dari blockchain berdasarkan ID.",
        "parameters": [
          {
            "name": "issuerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "DEMO_ISSUER"
          }
        ],
        "responses": {
          "200": {
            "description": "Issuer data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "issuerId": {
                          "type": "string",
                          "example": "DEMO_ISSUER"
                        },
                        "organizationName": {
                          "type": "string",
                          "example": "Demo University"
                        },
                        "departmentName": {
                          "type": "string",
                          "example": "Academic Office"
                        },
                        "mspId": {
                          "type": "string",
                          "example": "Org1MSP"
                        },
                        "status": {
                          "type": "string",
                          "example": "ACTIVE"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/issuers/{issuerId}/exists": {
      "get": {
        "summary": "Cek Keberadaan Issuer",
        "description": "Memeriksa apakah issuer terdaftar aktif di blockchain ledger.",
        "parameters": [
          {
            "name": "issuerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Boolean status returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/issuers/{issuerId}/certificates": {
      "get": {
        "summary": "Daftar Sertifikat Berdasarkan Issuer",
        "description": "Mengambil semua daftar sertifikat yang diterbitkan oleh issuer tertentu langsung dari blockchain.",
        "parameters": [
          {
            "name": "issuerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of certificates retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/LedgerCertificateAsset"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates": {
      "post": {
        "summary": "Penerbitan Sertifikat (Ledger Direct)",
        "description": "Mendaftarkan sertifikat baru secara langsung ke blockchain ledger (tanpa mengunggah file fisik).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueCertificateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Certificate issued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "string",
                      "example": ""
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Daftar Semua Sertifikat (Ledger)",
        "description": "Mengambil rekaman sertifikat dari world state blockchain. Jika parameter issuerId ditentukan, ia akan menyaring sertifikat untuk penerbit tersebut saja.",
        "parameters": [
          {
            "name": "issuerId",
            "in": "query",
            "required": false,
            "description": "ID issuer untuk menyaring sertifikat.",
            "schema": {
              "type": "string"
            },
            "example": "DEMO_ISSUER"
          }
        ],
        "responses": {
          "200": {
            "description": "List of ledger certificates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/LedgerCertificateAsset"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates/{certificateId}": {
      "get": {
        "summary": "Detail Sertifikat (Ledger)",
        "description": "Mendapatkan data aset sertifikat dari blockchain berdasarkan ID sertifikat.",
        "parameters": [
          {
            "name": "certificateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sertifikat ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/LedgerCertificateAsset"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates/{certificateId}/exists": {
      "get": {
        "summary": "Cek Keberadaan Sertifikat",
        "description": "Memeriksa apakah sertifikat terdaftar di blockchain ledger.",
        "parameters": [
          {
            "name": "certificateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Boolean status returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates/{certificateId}/verify": {
      "post": {
        "summary": "Verifikasi Sertifikat (Ledger Direct)",
        "description": "Memvalidasi status dan kecocokan sidik jari berkas sertifikat (IPFS CID) secara langsung ke blockchain ledger.",
        "parameters": [
          {
            "name": "certificateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ipfsCid": {
                    "type": "string",
                    "description": "IPFS CID dari berkas sertifikat yang ingin dicocokkan.",
                    "example": "bafkreiagd7rpkbe4s3lsljm2vnk23wrf6e3vsjhrk43z5daxaea7bofgea"
                  }
                },
                "required": [
                  "ipfsCid"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "certificateId": {
                          "type": "string",
                          "example": "UUID-123"
                        },
                        "valid": {
                          "type": "boolean",
                          "example": true
                        },
                        "status": {
                          "type": "string",
                          "example": "ACTIVE"
                        },
                        "issuerId": {
                          "type": "string",
                          "example": "DEMO_ISSUER"
                        },
                        "certificateType": {
                          "type": "string",
                          "example": "DIPLOMA"
                        },
                        "message": {
                          "type": "string",
                          "example": "certificate is valid"
                        },
                        "issuedAt": {
                          "type": "string",
                          "example": "2026-06-27"
                        },
                        "revoked": {
                          "type": "boolean",
                          "example": false
                        },
                        "tampered": {
                          "type": "boolean",
                          "example": false
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates/{certificateId}/revoke": {
      "post": {
        "summary": "Pencabutan Sertifikat (Revocation)",
        "description": "Membatalkan status aktif sertifikat di blockchain.",
        "parameters": [
          {
            "name": "certificateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string",
                    "description": "Alasan penarikan dokumen",
                    "example": "Salah ketik nilai IPK"
                  },
                  "reasonHash": {
                    "type": "string",
                    "description": "Hash SHA256 alasan penarikan (opsional jika alasan raw diberikan)",
                    "example": "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"
                  },
                  "revokedAt": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-06-29T08:00:00Z"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certificate revoked",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "string",
                      "example": ""
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates/{certificateId}/revocation": {
      "get": {
        "summary": "Informasi Pencabutan",
        "description": "Mendapatkan rekaman alasan pencabutan sertifikat jika statusnya REVOKED.",
        "parameters": [
          {
            "name": "certificateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Revocation details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "certificateId": {
                          "type": "string",
                          "example": "UUID-123"
                        },
                        "reasonHash": {
                          "type": "string",
                          "example": "2cf24dba..."
                        },
                        "revokedAt": {
                          "type": "string",
                          "example": "2026-06-29T08:00:00Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/certificates/{certificateId}/history": {
      "get": {
        "summary": "Riwayat Perubahan Audit",
        "description": "Mendapatkan seluruh history transaksi dan perubahan status sertifikat dari blockchain ledger.",
        "parameters": [
          {
            "name": "certificateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "History transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "txId": {
                            "type": "string",
                            "example": "tx-12345"
                          },
                          "timestamp": {
                            "type": "string",
                            "example": "2026-06-29T08:00:00Z"
                          },
                          "isDelete": {
                            "type": "boolean",
                            "example": false
                          },
                          "value": {
                            "$ref": "#/components/schemas/LedgerCertificateAsset"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/upload": {
      "post": {
        "summary": "Unggah & Terbitkan Ijazah (PDF Multipart)",
        "description": "Endpoint utama untuk institusi. Mengunggah file ijazah PDF ke IPFS secara otomatis, mencatat CID-nya ke Hyperledger Fabric, dan menyinkronkan metadata ke database relasional PostgreSQL.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file_ijazah": {
                    "type": "string",
                    "format": "binary",
                    "description": "Berkas berkas ijazah berformat PDF."
                  },
                  "certificateNumber": {
                    "type": "string",
                    "example": "CERT-2026-TI-0001"
                  },
                  "issuerId": {
                    "type": "string",
                    "example": "DEMO_ISSUER"
                  },
                  "organizationName": {
                    "type": "string",
                    "example": "Demo University"
                  },
                  "departmentName": {
                    "type": "string",
                    "example": "Academic Office"
                  },
                  "mspId": {
                    "type": "string",
                    "example": "Org1MSP"
                  },
                  "certificateType": {
                    "type": "string",
                    "example": "DIPLOMA"
                  },
                  "degreeTitle": {
                    "type": "string",
                    "example": "Bachelor of Computer Science"
                  },
                  "studentId": {
                    "type": "string",
                    "description": "NIM Mahasiswa (raw, backend otomatis akan meng-hash ke StudentIdHash)",
                    "example": "NIM-12345"
                  },
                  "studentName": {
                    "type": "string",
                    "example": "John Doe"
                  },
                  "studyProgram": {
                    "type": "string",
                    "example": "Teknik Informatika"
                  },
                  "educationLevel": {
                    "type": "string",
                    "example": "S1"
                  },
                  "graduationDate": {
                    "type": "string",
                    "format": "date",
                    "description": "Format YYYY-MM-DD (opsional)",
                    "example": "2026-06-30"
                  },
                  "issuedAt": {
                    "type": "string",
                    "format": "date",
                    "description": "Format YYYY-MM-DD",
                    "example": "2026-06-27"
                  },
                  "expiredAt": {
                    "type": "string",
                    "format": "date",
                    "description": "Format YYYY-MM-DD (opsional)",
                    "example": ""
                  },
                  "faculty": {
                    "type": "string",
                    "example": "Fakultas Teknik"
                  }
                },
                "required": [
                  "file_ijazah",
                  "certificateNumber",
                  "issuerId",
                  "organizationName",
                  "departmentName",
                  "mspId",
                  "certificateType",
                  "degreeTitle",
                  "studentId",
                  "studentName",
                  "faculty",
                  "studyProgram",
                  "educationLevel",
                  "issuedAt"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Upload and registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Certificate uploaded successfully"
                    },
                    "data": {
                      "$ref": "#/components/schemas/DatabaseCertificate"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/verify/{nomorIjazah}": {
      "get": {
        "summary": "Verifikasi & Pencarian Nomor Ijazah",
        "description": "Endpoint utama untuk publik / frontend. Mencari sertifikat di DB lokal berdasarkan nomor ijazah, melakukan verifikasi kecocokan data ke blockchain ledger, dan merender tautan dokumen asli jika terbukti otentik.",
        "parameters": [
          {
            "name": "nomorIjazah",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "CERT-2026-TI-0001"
          }
        ],
        "responses": {
          "200": {
            "description": "Hasil pencarian dan status verifikasi keaslian",
            "content": {
              "application/json": {
                "schema": {
