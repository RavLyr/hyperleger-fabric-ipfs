    "/api/": {
      "get": {
        "summary": "Daftar Semua Sertifikat (Database)",
        "description": "Mengambil daftar sertifikat yang tersimpan di database lokal PostgreSQL. Jika parameter issuerId ditentukan, ia hanya mengambil sertifikat yang diterbitkan oleh issuer tersebut.",
        "parameters": [
          {
            "name": "issuerId",
            "in": "query",
            "required": false,
            "description": "ID issuer untuk menyaring sertifikat.",
            "schema": {
              "type": "string"
            },
            "example": "DEMO_ISSUER"
          }
        ],
        "responses": {
          "200": {
            "description": "List of local database certificates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DatabaseCertificate"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
